\NeedsTeXFormat{LaTeX2e}[1999/01/01]
\ProvidesPackage{ulille-macros}[2022/01/27]

\RequirePackage[english,french]{babel}
\RequirePackage{calc,tikz}
\RequirePackage{xspace}
\RequirePackage{microtype}

%% polices
\RequirePackage{fontspec}
\defaultfontfeatures[\rmfamily,\sffamily]{Ligatures=TeX}
\setmainfont{Marianne}[
    Extension = .otf,
    UprightFont = *-Regular,
    BoldFont = *-Bold,
    ItalicFont = *-RegularItalic,
    BoldItalicFont = *-BoldItalic]
\setsansfont[Scale=MatchLowercase]{Spectral}[
    Extension = .ttf,
    UprightFont = *-Regular,
    BoldFont = *-Bold,
    ItalicFont = *-Italic,
    BoldItalicFont = *-BoldItalic]
\setmonofont[Scale=MatchUppercase,%
    ItalicFont=NewCMMono10-Italic.otf,%
    BoldFont=NewCMMono10-Bold.otf,%
    BoldItalicFont=NewCMMono10-BoldOblique.otf,%
    SmallCapsFeatures={Numbers=OldStyle}]{NewCMMono10-Regular.otf}
%\setmonofont[Scale=MatchLowercase]{Latin Modern Mono Light}
\renewcommand{\baselinestretch}{1.2}

